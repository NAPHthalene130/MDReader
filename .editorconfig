root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,yaml,yml,md,html,css,scss,svg}]
indent_style = space
indent_size = 2

[*.{ts,js,tsx,jsx}]
indent_style = space
indent_size = 4

[*.{kt,kts,java}]
indent_style = space
indent_size = 4

[*.{xml,gradle}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.{bat,cmd,ps1}]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false

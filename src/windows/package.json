{
  "name": "md-reader-windows",
  "version": "1.1.0",
  "private": true,
  "description": "MDReader Windows desktop app (Electron)",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.mdreader.app",
    "productName": "MDReader",
    "directories": {
      "output": "../../.build/windows"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../core/dist",
        "to": "core-bundle"
      },
      {
        "from": "../../mermaid.min.js",
        "to": "assets/mermaid.min.js"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  }
}

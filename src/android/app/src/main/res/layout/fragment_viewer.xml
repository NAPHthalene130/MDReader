<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical"
            android:background="@android:color/white"
            android:elevation="2dp">

            <Button
                android:id="@+id/viewer_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/back"
                android:textSize="14sp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <TextView
                android:id="@+id/viewer_filename"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="16sp"
                android:textColor="#24292e"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingHorizontal="8dp" />

            <Button
                android:id="@+id/viewer_toc_toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/toc_title"
                android:textSize="14sp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />
        </LinearLayout>

        <WebView
            android:id="@+id/viewer_webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/toc_content"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#f6f8fa"
        android:padding="16dp">

        <TextView
            android:id="@+id/toc_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/toc_title"
            android:textSize="14sp"
            android:textColor="#24292e"
            android:paddingBottom="12dp" />
    </ScrollView>
</androidx.drawerlayout.widget.DrawerLayout>
